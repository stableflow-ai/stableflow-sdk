# StableFlow API Configuration
# Copy to .env.local and fill in your values (not committed).

# Default (production)
VITE_STABLEFLOW_API_URL=https://api.stableflow.ai
VITE_STABLEFLOW_JWT_TOKEN=

VITE_STABLEFLOW_TEST_API_URL=https://api.stableflow.ai
VITE_STABLEFLOW_TEST_JWT_TOKEN=
# JWT for NearIntents(1click) API calls (optional)
VITE_STABLEFLOW_NEARINTENTS_JWT_TOKEN=

# WalletConnect project ID for RainbowKit (required for EVM wallet connect)
# https://dashboard.reown.com/
VITE_WALLET_CONNECT_PROJECT_ID=

# TON RPC API key (optional, used by TON wallet adapter)
VITE_TON_RPC_API_KEY=
