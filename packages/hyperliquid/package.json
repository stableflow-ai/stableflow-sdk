{
  "name": "@stableflow/hyperliquid",
  "version": "3.0.0",
  "description": "Hyperliquid helpers for StableFlow SDK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/stableflow-ai/stableflow-sdk.git",
    "directory": "packages/hyperliquid"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
